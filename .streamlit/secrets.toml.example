# 部署到 Streamlit Community Cloud 時，把這份檔案的內容貼到
# Manage app → Settings → Secrets 介面（不要直接 commit secrets.toml）。
#
# 本機開發二選一：
#   1. 複製此檔為 .streamlit/secrets.toml（已在 .gitignore）
#   2. 直接設環境變數：export ANTHROPIC_API_KEY=sk-ant-...

# 必填：Anthropic API 金鑰（liveAI 模式才需要；沒設會退回 demo 模式跑預錄回答）
ANTHROPIC_API_KEY = "sk-ant-api03-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"

# 選填：模型覆寫（預設 claude-sonnet-4-5，見 config.py）
# CLAUDE_MODEL = "claude-opus-4-7"

# 選填：max_tokens 上限（預設 2048，見 config.py）
# MAX_TOKENS = "4096"

# 選填：日誌級別（預設 INFO，見 logger.py）
# LOG_LEVEL = "DEBUG"
